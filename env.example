# Facebook API Configuration
FACEBOOK_PAGE_ID=your_page_id_here
FACEBOOK_ACCESS_TOKEN=your_long_lived_access_token_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Unsplash API (Optional - for fallback images)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# BoardGameGeek API (Required)
# Get your token at: https://boardgamegeek.com/applications
# 1. Register your application (approval may take a week)
# 2. Create a token for your application
BGG_API_TOKEN=your_bgg_api_token_here

# Environment
ENVIRONMENT=development

